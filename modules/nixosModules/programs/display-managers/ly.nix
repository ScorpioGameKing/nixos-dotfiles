{ lib, config, ... }: 

{

  options = { };
  
  config = lib.mkIf config.nixos-modules.display-managers.ly.enable {
    services.displayManager.ly = {
      enable = true;
      settings = {
        allow_empty_password = true;
        animation = config.nixos-modules.display-managers.ly.settings.animation;
        animation_frame_delay = 5;
        animation_timeout_sec = 0;
        asterisk = "*";
        auth_fails = 10;
        auto_login_session = "null";
        auto_login_user = "null";
        battery_id = "null";
        bg = "0x00000000";
        bigclock = "none";
        bigclock_12hr = false;
        bigclock_seconds = false;
        blank_box = true;
        border_fg = "0x00FFFFFF";
        box_position_h = 0.5;
        box_position_v = 0.5;
        box_title = config.nixos-modules.display-managers.ly.settings.box_title;
        brightness_down_cmd = "$PREFIX_DIRECTORY/bin/brightnessctl -q -n s 10%-";
        brightness_down_key = "F5";
        brightness_up_cmd = "$PREFIX_DIRECTORY/bin/brightnessctl -q -n s +10%";
        brightness_up_key = "F6";
        clear_password = false;
        clock = config.nixos-modules.display-managers.ly.settings.clock;
        cmatrix_min_codepoint = config.nixos-modules.display-managers.ly.settings.cmatrix_min_codepoint;
        cmatrix_max_codepoint = config.nixos-modules.display-managers.ly.settings.cmatrix_max_codepoint;
        colormix_col1 = config.nixos-modules.display-managers.ly.settings.colormix_col1;
        colormix_col2 = config.nixos-modules.display-managers.ly.settings.colormix_col2;
        colormix_col3 = config.nixos-modules.display-managers.ly.settings.colormix_col3;
        corner_top_left = config.nixos-modules.display-managers.ly.settings.corner_top_left;
        corner_top_right = config.nixos-modules.display-managers.ly.settings.corner_top_right;
        cmatrix_fg = "0x0000FF00";
        cmatrix_head_col = "0x01FFFFFF";
        corner_bottom_left = "version";
        corner_bottom_right = "labels";
        custom_bind_width = "null";
        custom_sessions = "$CONFIG_DIRECTORY/ly/custom-sessions";
        default_input = "login";
        doom_fire_height = 6;
        doom_fire_spread = 2;
        doom_top_color = "0x009F2707";
        doom_middle_color = "0x00C78F17";
        doom_bottom_color = "0x00FFFFFF";
        dur_file_path = "$CONFIG_DIRECTORY/ly/example.dur";
        dur_offset_alignment = "center";
        dur_x_offset = 0;
        dur_y_offset = 0;
        edge_margin = 0;
        error_bg = "0x00000000";
        error_fg = "0x01FF0000";
        fg = "0x00FFFFFF";
        full_color = true;
        gameoflife_entropy_interval = 10;
        gameoflife_fg = "0x0000FF00";
        gameoflife_frame_delay = 6;
        gameoflife_initial_density = 0.4;
        hide_borders = false;
        inactivity_cmd = "null";
        inactivity_delay = 0;
        initial_info_text = "null";
        input_len = 34;
        lang = "en";
        login_cmd = "null";
        login_defs_path = "/etc/login.defs";
        logout_cmd = "null";
        lua_animation_file = "$CONFIG_DIRECTORY/ly/example.lua";
        ly_log = "/var/log/ly.log";
        margin_box_h = 2;
        margin_box_v = 1;
        numlock = false;
        path = "/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin";
        restart_key = "F2";
        save_file_dir = "$CONFIG_DIRECTORY/ly";
        service_name = "ly";
        session_log = ".local/state/ly-session.log";
        setup_cmd = "$CONFIG_DIRECTORY/ly/setup.sh";
        shell = true;
        show_password_key = "F7";
        shutdown_key = "F1";
        start_cmd = "$CONFIG_DIRECTORY/ly/startup.sh";
        text_in_center = false;
        vi_default_mode = "normal";
        vi_mode = false;
        waylandsessions = "$PREFIX_DIRECTORY/share/wayland-sessions";
        x_cmd = "$PREFIX_DIRECTORY/bin/X";
        x_vt = "null";
        xauth_cmd = "$PREFIX_DIRECTORY/bin/xauth";
        xinitrc = "~/.xinitrc";
        xsessions = "$PREFIX_DIRECTORY/share/xsessions";
      };
    };
  };
}
